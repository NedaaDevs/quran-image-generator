{
  "name": "quran-image-generator",
  "module": "index.ts",
  "type": "module",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "build": "bun build src/cli.ts --compile --outfile quran-gen && cp node_modules/pngquant-bin/vendor/pngquant .",
    "build:linux": "bun build src/cli.ts --compile --target=bun-linux-x64 --outfile quran-gen-linux",
    "build:mac": "bun build src/cli.ts --compile --target=bun-darwin-arm64 --outfile quran-gen && cp node_modules/pngquant-bin/vendor/pngquant ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "latest",
    "@types/pngjs": "^6.0.5",
    "lefthook": "^2.1.4"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "@napi-rs/canvas": "^0.1.96",
    "@napi-rs/image": "^1.12.0",
    "canvas": "^3.2.1",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "pngquant-bin": "^9.0.0"
  }
}
